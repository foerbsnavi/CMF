Options -Indexes

# GZIP-Kompression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Browser-Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType application/zip "access plus 1 month"
</IfModule>

# Cache-Control Header
# CSS/JS werden per ?v=-Query-String versioniert — immutable ist daher sicher
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(ttf|woff|woff2|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Security-Header (defense-in-depth, always = auch auf Fehler-/401-Antworten)
# CSP bewusst mit 'unsafe-inline' fuer script/style: der html-Block liefert gewollt
# rohes HTML/Embeds aus und der Admin nutzt Inline-Skripte (Login-Countdown, Sortierung,
# Bild-Picker). Der eigentliche Schutz gegen den javascript:-Vektor liegt in der
# URL-Schema-Whitelist im Code (Sanitizer/Renderer), nicht hier. img/media/frame bleiben
# fuer https: offen, damit eingebettete Inhalte nicht brechen; frame-ancestors/base-uri/
# form-action/object-src greifen dennoch hart. HSTS bewusst NICHT gesetzt (schwer umkehrbar).
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; media-src 'self' https:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-src 'self' https:; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
</IfModule>

# URL-Rewriting
<IfModule mod_rewrite.c>
RewriteEngine On

# HTTPS erzwingen (301) — X-Forwarded-Proto verhindert Redirect-Schleifen hinter Proxys
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Optional: www auf non-www umleiten — bei Bedarf einkommentieren
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Keine Skript-Ausfuehrung in Upload-/Download-Ordnern
# ($|\.) faengt auch Multi-Extensions wie bild.php.jpg ab
RewriteRule ^(media|files)/.+\.(php[0-9]*|phtml|phar|cgi|pl|shtml)($|\.) - [F,NC]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [L,QSA]
</IfModule>
