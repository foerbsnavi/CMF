Options -Indexes

# GZIP-Kompression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Browser-Caching
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  ExpiresByType application/x-font-ttf "access plus 1 year"
  ExpiresByType application/zip "access plus 1 month"
</IfModule>

# Cache-Control Header
# CSS/JS werden per ?v=-Query-String versioniert — immutable ist daher sicher
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(ttf|woff|woff2|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Security-Header (defense-in-depth, always = auch auf Fehler-/401-Antworten).
# Die Content-Security-Policy wird NICHT mehr hier gesetzt, sondern dynamisch von
# PHP (App\Core\Csp, aus Bootstrap.php) — so ist sie pro Installation ueber
# config/site.json "csp" erweiterbar, ohne die strenge Basis aufzuweichen. Die
# uebrigen Header bleiben statisch hier (sie muessen nicht konfigurierbar sein).
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
</IfModule>

# URL-Rewriting
<IfModule mod_rewrite.c>
RewriteEngine On

# HTTPS erzwingen (301) — X-Forwarded-Proto verhindert Redirect-Schleifen hinter Proxys
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Optional: www auf non-www umleiten — bei Bedarf einkommentieren
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Keine Skript-Ausfuehrung in Upload-/Download-Ordnern
# ($|\.) faengt auch Multi-Extensions wie bild.php.jpg ab
RewriteRule ^(media|files)/.+\.(php[0-9]*|phtml|phar|cgi|pl|shtml)($|\.) - [F,NC]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.php [L,QSA]
</IfModule>
